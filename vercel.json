{\n  "version": 2,\n  "buildCommand": "npm run build",\n  "outputDirectory": ".",\n  "env": {\n    "NODE_ENV": "production"\n  },\n  "routes": [\n    {\n      "src": "/landing.html",\n      "dest": "/landing.html"\n    },\n    {\n      "src": "/(.*)",\n      "dest": "/landing.html"\n    }\n  ],\n  "headers": [\n    {\n      "source": "/(.*)",\n      "headers": [\n        {\n          "key": "Cache-Control",\n          "value": "public, max-age=3600, s-maxage=3600"\n        },\n        {\n          "key": "X-Content-Type-Options",\n          "value": "nosniff"\n        }\n      ]\n    }\n  ]\n}